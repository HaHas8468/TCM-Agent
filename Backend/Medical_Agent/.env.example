APP_ENV=production
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=traditional_medical
MYSQL_USER=tcm_app
MYSQL_PASSWORD=replace-with-strong-password
MYSQL_ROOT_PASSWORD=replace-with-another-strong-password
REDIS_URL=redis://redis:6379/0
AGENT_BASE_URL=http://agent:8001
AGENT_API_KEY=replace-with-a-long-random-internal-key
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:3000,http://localhost:3000
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-strong-password
NEO4J_CASE_URI=bolt://neo4j:7687
NEO4J_CASE_USERNAME=neo4j
NEO4J_CASE_PASSWORD=replace-with-strong-password
NEO4J_CASE_DATABASE=neo4j
AGENT_MAX_CONCURRENCY=4
AGENT_TIMEOUT_SECONDS=90
AGENT_STREAM_CHUNK_SIZE=12
AGENT_STREAM_CHUNK_DELAY_SECONDS=0.06
AGENT_SESSION_TTL_SECONDS=3600
KG_SERVICE_BASE_URL=http://kg:3000
KG_SERVICE_TIMEOUT_SECONDS=20
KG_MAX_CONCURRENCY=2
KG_NODE_MAX_CONCURRENCY=4
KG_NODE_MAX_BODY_BYTES=65536
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_WRITE_PER_MINUTE=30
RATE_LIMIT_AGENT_PER_MINUTE=10
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
LLM_MODEL_32B=qwen-plus
